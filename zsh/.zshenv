# change config path
export ZDOTDIR="$HOME/.config/zsh"
export HISTFILE="$HOME/.zsh_history"

#change vim config path
export VIMHOME="$HOME/.config/vim"

# EDITOR Env variable
export EDITOR="nvim"

# pyenv
export PYENV_ROOT="$HOME/.pyenv"

# CLI colors
export CLICOLOR=1

# Nix stuff
export NIXPKGS_ALLOW_UNFREE=1
